{"_id": "insight-china-rwe", "_type": "insight", "title": {"_type": "localizedString", "en": "China Real-World Evidence: What Travels Across Borders, and What Doesn't"}, "slug": {"_type": "slug", "current": "china-rwe-what-travels"}, "type": "regulatory", "summary": {"_type": "localizedText", "en": "Real-world evidence generated in China is increasingly cited in global submissions — but not all of it travels. We separate what regulators outside China tend to accept, what they question, and what teams should plan to re-derive locally before quoting it in an FDA or EMA package."}, "authors": [{"_type": "reference", "_ref": "person-dr-l-chen"}], "publishedAt": "2026-04-15T00:00:00Z", "readTime": 6, "tags": ["rwe", "china", "fda", "ema"]}
{"_id": "insight-fda-bridge", "_type": "insight", "title": {"_type": "localizedString", "en": "Bridging China-Generated Data to an FDA Submission: A Field Checklist"}, "slug": {"_type": "slug", "current": "china-data-fda-bridge"}, "type": "regulatory", "summary": {"_type": "localizedText", "en": "Most China-headquartered sponsors arrive at the FDA conversation with strong domestic data and an unclear sense of which parts will translate. We share the gating questions our reviewers run before a single page of a U.S.-facing dossier gets drafted — and the three places that bridges most often fail."}, "authors": [{"_type": "reference", "_ref": "person-dr-r-iyer"}], "publishedAt": "2026-04-08T00:00:00Z", "readTime": 7, "tags": ["fda", "evidence-bridge", "china"]}
{"_id": "insight-bilingual", "_type": "insight", "title": {"_type": "localizedString", "en": "Bilingual Medical Content That Both Tracks Will Sign"}, "slug": {"_type": "slug", "current": "bilingual-content-both-tracks-sign"}, "type": "medical_affairs", "summary": {"_type": "localizedText", "en": "Translating EN clinical content into CN — or the reverse — is rarely the actual problem. The actual problem is that two physician tracks need to sign off the same artifact, against two different regulatory and stylistic frames. We share the parallel-reviewer model we use, and where it shortens revision cycles by half."}, "authors": [{"_type": "reference", "_ref": "person-dr-s-tan"}], "publishedAt": "2026-03-30T00:00:00Z", "readTime": 5, "tags": ["bilingual", "medical-communications", "review-workflow"]}
