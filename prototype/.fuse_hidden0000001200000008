<style>
html, body { margin: 0; padding: 0; background: var(--bg-1); color: var(--fg-1); font-family: var(--font-ui); }
  *, *::before, *::after { box-sizing: border-box; }
  a { color: inherit; }
</style>
</head>
<body>
<div id="root"></div>

<script src="assets/vendor/react.development.js"></script>
<script src="assets/vendor/react-dom.development.js"></script>
<script src="assets/vendor/babel.min.js"></script>
<script src="assets/vendor/lucide.min.js"></script>

<script type="text/babel" src="components/Button.jsx"></script>
<script type="text/babel" src="components/Header.jsx"></script>
<script type="text/babel" src="components/Footer.jsx"></script>
<script type="text/babel" src="components/PageShell.jsx"></script>
<script type="text/babel" src="components/ContentBlocks.jsx"></script>
<script type="text/babel" src="components/SmartForm.jsx"></script>

<script type="text/babel">
function App() {
  return (
    <PageShell hideHero breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Contact' }
    ]}>
      {/* Hero */}
      <section style={{
        maxWidth: 880,
        margin: '0 auto',
        padding: 'clamp(48px, 6vw, 96px) clamp(24px, 6vw, 96px) 32px'
      }}>
        <div style={{
          fontFamily: 'var(--font-slogan)',
          fontSize: 12,
          letterSpacing: '0.16em',
          textTransform: 'uppercase',
          color: 'var(--brand-accent-700)',
          marginBottom: 16
        }}>Contact MedSci Healthcare</div>

        <h1 style={{
          fontFamily: 'var(--font-display)',
          fontSize: 'clamp(32px, 5vw, 48px)',
          lineHeight: 1.2,
          color: 'var(--brand-primary-700)',
          margin: '0 0 20px'
        }}>Talk to a physician on our team.</h1>

        <p style={{
          fontSize: 17,
          color: 'var(--fg-1)',
          lineHeight: 1.6,
          margin: 0,
          maxWidth: 720
        }}>
          Tell us a bit about what you're working on. We route by business block — Evidence, Physician Engagement, Communications, AI Platform — and the same person who reaches out is on the deliverable when work begins.
        </p>
      </section>

      {/* Form */}
      <section style={{ padding: '0 0 64px' }}>
        <SmartForm />
      </section>

      {/* Side info: routing transparency + alt channels */}
      <section style={{
        maxWidth: 720,
        margin: '0 auto',
        padding: '0 clamp(24px, 6vw, 96px) 96px'
      }}>
        <div style={{
          borderTop: '1px solid var(--border-1)',
          paddingTop: 32,
          fontSize: 14,
          color: 'var(--fg-2)',
          lineHeight: 1.6
        }}>
          <div style={{
            fontFamily: 'var(--font-slogan)',
            fontSize: 12,
            letterSpacing: '0.12em',
            textTransform: 'uppercase',
            color: 'var(--brand-primary-700)',
            marginBottom: 12
          }}>How we route this</div>

          <p style={{ margin: '0 0 12px' }}>
            Pilot and Expert intents go to BD by business block. RFP intent routes to our formal-proposal queue. Investor and Press inquiries are best routed through their dedicated channels below.
          </p>

          <ul style={{ listStyle: 'none', padding: 0, margin: '20px 0 0' }}>
            <li style={{ marginBottom: 8 }}>
              → Investor Relations (HKEX 2415.HK):{' '}
              <a href="https://ir.medsci.cn/en/" rel="external noopener" style={{ color: 'var(--fg-link)', textDecoration: 'underline' }}>
                ir.medsci.cn/en/
              </a>
            </li>
            <li style={{ marginBottom: 8 }}>
              → Press &amp; Media: select <em>Other</em> above and mention your outlet and deadline.
            </li>
            <li style={{ marginBottom: 8 }}>
              → Compliance / vendor security pack: select <em>Other</em> above and describe your audit context.
            </li>
            <li style={{ marginBottom: 0 }}>
              → Existing engagement &amp; account questions: please use the email thread from your engagement letter.
            </li>
          </ul>
        </div>
      </section>
    </PageShell>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>
